namespace App\Notifications;

use Illuminate\Bus\Queueable;
use Illuminate\Contracts\Queue\ShouldQueue;
use Illuminate\Notifications\Messages\MailMessage;
use Illuminate\Notifications\Notification;

class AdminMessageNotification extends Notification
{
    use Queueable;

    public $title;
    public $message;
    public $originalTitle;
    public $languageCode;
    public $country;

    public function __construct($title, $message, $originalTitle = null, $languageCode = 'en', $country = null)
    {
        $this->title = $title;
        $this->message = $message;
        $this->originalTitle = $originalTitle;
        $this->languageCode = $languageCode;
        $this->country = $country;
    }

    public function via($notifiable)
    {
        return ['mail'];
    }

    public function toMail($notifiable)
    {
        return (new MailMessage)
            ->subject($this->title)
            ->view('emails.admin-message', [
                'subject' => $this->title,
                'userName' => $notifiable->name,
                'messageBody' => $this->message,
                'originalTitle' => $this->originalTitle,
                'languageCode' => $this->languageCode,
                'country' => $this->country,
                'actionUrl' => route('user.dashboard'),
                'actionText' => 'View Dashboard',
                'previewText' => 'You have a new message from MarketMind'
            ]);
    }
}




